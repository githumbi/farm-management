# Copy to .env.local at repo root and fill in real values.

# --- Database ---
# Owner role: prisma migrate only.
DATABASE_URL=postgresql://shamba:shamba@localhost:5432/shambatrack?schema=public
# Non-superuser role: runtime app queries (RLS enforced).
DATABASE_APP_URL=postgresql://shamba_app:shamba_app@localhost:5432/shambatrack?schema=public

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- WhatsApp Cloud API (Meta) ---
WA_ACCESS_TOKEN=
WA_PHONE_NUMBER_ID=
WA_BUSINESS_ACCOUNT_ID=
WA_APP_SECRET=
WA_VERIFY_TOKEN=
WA_API_VERSION=v25.0

# --- Auth.js (set in M2) ---
# AUTH_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# --- Cloudflare R2 (set in M8) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=

# --- Resend (set in M16) ---
# RESEND_API_KEY=
# RESEND_FROM=
